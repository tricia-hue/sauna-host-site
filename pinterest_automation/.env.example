# Pinterest API credentials — fill these in from https://developers.pinterest.com/apps/1565235/
# DO NOT commit the real .env file — it's gitignored.

# App ID (also called Client ID)
PINTEREST_APP_ID=1565235

# App Secret Key (available once trial access is approved)
PINTEREST_APP_SECRET=

# Trial access token — generated immediately from the developer portal.
# Read-only scopes: pins:read, boards:read, user_accounts:read, ads:read, catalogs:read.
# Use this for analytics work while waiting for full OAuth approval.
PINTEREST_TRIAL_TOKEN=

# Refresh token — populated by oauth_helper.py after first authorization.
PINTEREST_REFRESH_TOKEN=

# Access token — populated by oauth_helper.py; auto-refreshed when expired.
PINTEREST_ACCESS_TOKEN=

# Redirect URI — must EXACTLY match what's registered in the developer portal.
PINTEREST_REDIRECT_URI=http://localhost:8085/
