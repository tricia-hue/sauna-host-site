# The Sauna Host — environment variables
#
# Copy this file to .env.local (for local dev) and add the real values.
# For production, set these in Vercel → Project → Settings → Environment Variables.

# --- Brevo (default ESP) ---------------------------------------------------
# If any of these are missing, the subscribe route will log to console
# and return success (dev-mode fallback) so the UX still works.

BREVO_API_KEY=
BREVO_LIST_ID=

# Optional — tag written to the SOURCE contact attribute in Brevo.
# Defaults to "sauna-host-course" if not set.
BREVO_SOURCE_TAG=sauna-host-course

# --- Optional: Klaviyo / ConvertKit / Mailchimp swap -----------------------
# If you want to use a different ESP, replace /lib/email.ts with your
# implementation — the API contract is tiny (see that file's top comment).
